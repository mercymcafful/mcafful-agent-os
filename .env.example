# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, never expose

# Mercy's auth user id (the single agent this OS serves). Create her user in Supabase Auth, paste the uuid.
AGENT_ID=00000000-0000-0000-0000-000000000000

# --- WhatsApp Business Cloud API (Meta) ---
WHATSAPP_TOKEN=your-permanent-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_VERIFY_TOKEN=make-up-a-string-and-paste-it-in-meta-webhook-config
WHATSAPP_NOTIFY_TO=27XXXXXXXXX          # Mercy's own number, for new-lead pings

# --- Anthropic (AI lead qualifier) ---
ANTHROPIC_API_KEY=sk-ant-...
