# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Mercy's agent user id (her Supabase auth user UID).
AGENT_ID=

# --- WhatsApp Business Cloud API ---
# WHATSAPP_VERIFY_TOKEN: any random string you make up yourself — used only
# to verify the webhook belongs to you when Meta calls it.
WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_TOKEN: the access token from Meta's WhatsApp > API Setup page.
WHATSAPP_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID: from the same API Setup page (a numeric ID, not
# the phone number itself).
WHATSAPP_PHONE_NUMBER_ID=
